# Copy to .env and fill in. The Anthropic SDK also reads ANTHROPIC_API_KEY directly
# from the environment or an `ant auth login` profile, so the chat endpoint works
# without this file as long as a key is configured in your shell.

ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional overrides (defaults shown)
WEALTH_MODEL=claude-opus-4-8
WEALTH_EFFORT=medium
WEALTH_DATA_PROVIDER=mock
